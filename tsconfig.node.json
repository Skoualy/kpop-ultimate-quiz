{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts"],
  "types": ["node"]
}
